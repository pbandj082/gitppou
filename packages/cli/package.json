{
  "name": "@gitppou/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gitppou": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p ../core/tsconfig.build.json && tsc -p tsconfig.build.json",
    "check": "tsc -p ../core/tsconfig.build.json && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src",
    "preview": "node dist/index.js preview"
  },
  "dependencies": {
    "@gitppou/core": "workspace:*",
    "dotenv": "^17.4.2",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
