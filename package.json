{
  "name": "gitppou",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r --sort build",
    "check": "pnpm -r --sort check",
    "test": "pnpm -r --sort test",
    "lint": "biome lint .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:tag": "node scripts/create-release-tag.mjs",
    "build:action": "pnpm --filter @gitppou/core build && pnpm --filter @gitppou/action build",
    "preview": "pnpm --filter @gitppou/cli build && node packages/cli/dist/index.js preview"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
